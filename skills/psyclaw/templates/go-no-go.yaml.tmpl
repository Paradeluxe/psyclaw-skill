name: go_nogo_task
version: "1.0"
description: Go/No-Go response inhibition task — {n_trials} trials

routines:
  - name: instructions
    duration: null
    components:
      - type: text
        text: |
          Go/No-Go task.
          A circle will appear. Press SPACE quickly when you see it (GO).
          When you see a square, DO NOT press (NO-GO).
          Press SPACE to begin.
        height: 0.04
      - type: keyboard
        keys: space
        duration: -1
        force_end: true

  - name: fixation
    duration: 0.5
    components:
      - type: text
        text: "+"
        height: 0.08
        color: white

  - name: trial
    duration: 1.5
    components:
      - type: text
        text: $stim_label
        color: $stim_color
        height: 0.15
        pos: [0, 0]
      - type: keyboard
        keys: space
        duration: 1.0
        store: response
        correct_ans: $correct_resp

  - name: thanks
    duration: 3.0
    components:
      - type: text
        text: "Thank you!"
        height: 0.05

loops:
  - name: main_loop
    start_routine: fixation
    end_routine: trial
    n_rounds: {n_trials}
    order: fullRandom
    is_trials: true
    spreadsheet:
      file: gonogo_conditions.xlsx
      columns:
        - name: stim_label
          type: str
        - name: stim_color
          type: str
        - name: is_go
          type: bool
        - name: correct_resp
          type: str
      rows:
        - stim_label: CIRCLE
          stim_color: green
          is_go: true
          correct_resp: space
        - stim_label: CIRCLE
          stim_color: green
          is_go: true
          correct_resp: space
        - stim_label: CIRCLE
          stim_color: green
          is_go: true
          correct_resp: space
        - stim_label: SQUARE
          stim_color: red
          is_go: false
          correct_resp: ""

stimuli: []

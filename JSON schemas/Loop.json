{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loop",
  "description": "PsychoPy Loop component for repeating trials",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier for the loop"
    },
    "name": {
      "type": "string",
      "description": "Name of the loop"
    },
    "description": {
      "type": "string",
      "description": "Description of the stimuli content"
    },
    "nReps": {
      "type": "integer",
      "description": "Number of repetitions on the entire stimList",
      "default": 1
    },
    "varLists": {
      "type": "array",
      "items": {
        "$ref": "VarList.json"
      },
      "minItems": { "$data": "1/nReps" },
      "maxItems": { "$data": "1/nReps" }
    },
    "randomization": {
      "type": "string",
      "description": "Method for selecting conditions",
      "enum": ["random", "sequential", "fullRandom"],
      "default": "sequential"
    },
    "components": {
      "type": "array",
      "description": "Components to include in the loop",
      "items": {
        "oneOf": [
          { "$ref": "Slider.json" },
          { "$ref": "Text.json" },
          { "$ref": "Video.json" },
          { "$ref": "Audio.json" }
        ]
      }
    }
  },
  "required": ["id", "name", "description", "nReps", "varList"]
}
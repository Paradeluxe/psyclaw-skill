{
  "$schema": "https://json-schema.org/draft/2020-12/schema#",
  "title": "Loop",
  "description": "PsychoPy Loop component for repeating trials",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier for the loop"
    },
    "name": {
      "type": "string",
      "description": "Name of the loop"
    },
    "description": {
      "type": "string",
      "description": "Description of the stimuli content"
    },
    "nTrials": {
      "type": "integer",
      "description": "Number of trials on the entire Loop",
      "default": 1,
      "minimum": 1
    },
    "randomization": {
      "type": "string",
      "description": "Method for selecting conditions",
      "enum": ["random", "sequential", "fullRandom"],
      "default": "sequential"
    },
    "routines": {
      "type": "array",
      "description": "Routines to include in the loop",
      "items": {
        "$ref": "Routine.json"
      }
    }
  },
  "required": ["id", "name", "description", "nReps", "routines"]
}
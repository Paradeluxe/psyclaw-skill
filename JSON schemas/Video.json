{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Video",
  "description": "PsychoPy Video component for playing video",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier for the video component"
    },
    "name": {
      "type": "string",
      "description": "Name of the video component"
    },
    "movie": {
      "type": "string",
      "description": "A movie file (e.g. *.mp4, *.avi)"
    },
    "volume": {
      "type": "number",
      "description": "Volume level (0.0 to 1.0)",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 1.0
    },
    "loop": {
      "type": "boolean",
      "description": "Should the video loop?",
      "default": false
    },
    "stopWithRoutine": {
      "type": "boolean",
      "description": "Should the video stop when the Routine ends?",
      "default": true
    },
    "forceEndRoutine": {
      "type": "boolean",
      "description": "Should a response force the end of the Routine?",
      "default": true
    },
    "anchor": {
      "type": "string",
      "description": "Anchor point for the video",
      "enum": ["center", "top-center", "bottom-center", "center-left", "center-right", "top-left", "top-right", "bottom-left", "bottom-right"],
      "default": "center"
    },
    "pos": {
      "type": "array",
      "description": "Position on screen (x, y)",
      "items": {
        "type": "number"
      },
      "minItems": 2,
      "maxItems": 2,
      "default": [0, 0]
    },
    "size": {
      "type": "array",
      "description": "Size of the video (width, height)",
      "items": {
        "type": "number"
      },
      "minItems": 2,
      "maxItems": 2
    },
    "units": {
      "type": "string",
      "description": "Units to use when positioning",
      "enum": ["from exp settings", "norm", "cm", "deg", "pix", "height"],
      "default": "from exp settings"
    },
    "opacity": {
      "type": "number",
      "description": "Video opacity (0-1)",
      "minimum": 0,
      "maximum": 1,
      "default": 1.0
    },
    "minTime": {
      "type": "integer",
      "description": "Minimum time to play the video in milliseconds"
    },
    "maxTime": {
      "type": "integer",
      "description": "Maximum time to play the video in milliseconds"
    }
  },
  "required": ["id", "name", "description", "movie", "minTime", "maxTime"]
}

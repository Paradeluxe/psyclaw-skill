{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Video",
  "description": "PsychoPy Video component for playing video",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier for the video component"
    },
    "name": {
      "type": "string",
      "description": "Name of the video component"
    },
    "filePath": {
      "oneOf": [
        {
          "type": "string",
          "description": "Path to the video file"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Path to the video file or variable reference"
    },
    "size": {
      "oneOf": [
        {
          "type": "array",
          "description": "Size of the video (width, height)",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Size of the video (width, height) or variable reference"
    },
    "pos": {
      "oneOf": [
        {
          "type": "array",
          "description": "Position on screen (-1 to 1)",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Position on screen (-1 to 1) or variable reference",
      "default": [0.0, 0.0]
    },
    "opacity": {
      "oneOf": [
        {
          "type": "number",
          "description": "Video opacity (0-1)",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Video opacity (0-1) or variable reference",
      "default": 1.0
    },
    "loop": {
      "type": "boolean",
      "description": "Whether to loop the video",
      "default": false
    },
    "volume": {
      "oneOf": [
        {
          "type": "number",
          "description": "Volume level (0.0 to 1.0)",
          "minimum": 0.0,
          "maximum": 1.0
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Volume level (0.0 to 1.0) or variable reference",
      "default": 1.0
    },
    "startTime": {
      "oneOf": [
        {
          "type": "number",
          "description": "Start time of the video in seconds"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Start time of the video in seconds or variable reference",
      "default": 0.0
    },
    "stopTime": {
      "oneOf": [
        {
          "type": "number",
          "description": "Stop time of the video in seconds"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Stop time of the video in seconds or variable reference"
    },
    "autoPlay": {
      "type": "boolean",
      "description": "Whether to automatically play the video",
      "default": true
    },
    "isPlaying": {
      "type": "boolean",
      "description": "Whether the video is currently playing"
    },
    "isFinished": {
      "type": "boolean",
      "description": "Whether the video has finished playing"
    }
  },
  "required": ["id", "name", "filePath"]
}
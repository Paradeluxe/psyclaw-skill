{
  "$schema": "https://json-schema.org/draft/2020-12/schema#",
  "title": "VarList",
  "description": "PsychoPy Variable List base schema",
  "oneOf": [
    {
      "type": "array",
      "description": "Array of variable name strings",
      "items": { "type": "string" }
    },
    {
      "type": "array",
      "description": "Array of numeric values",
      "items": { "type": "number" }
    },
    {
      "type": "array",
      "description": "Array of null values for variables to be filled later",
      "items": { 
        "type": "null"
      }
    }
  ]
}
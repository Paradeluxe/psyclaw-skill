{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Routine",
  "description": "PsychoPy Routine settings component",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier for the routine"
    },
    "name": {
      "type": "string",
      "description": "Name of the routine"
    },
    "description": {
      "type": "string",
      "description": "Some descriptive text to give information about this Routine"
    },
    "color": {
      "type": "string",
      "description": "Color of the screen this Routine (e.g. black, $[1.0,1.0,1.0], $variable)",
      "default": "$[1.0,1.0,1.0]"
    },
    "backgroundImg": {
      "type": "string",
      "description": "Image file to use as a background (leave blank for no image)"
    },
    "varLists": {
      "type": "array",
      "description": "Variable lists inherited from the parent Loop",
      "items": {
        "$ref": "Loop.json#/properties/varLists/items"
      }
    },
    "components": {
      "type": "array",
      "description": "Components to include in the routine",
      "items": {
        "oneOf": [
          { "$ref": "Text.json" },
          { "$ref": "Video.json" },
          { "$ref": "Audio.json" },
          { "$ref": "Key.json" }
        ]
      }
    }
  },
  "required": ["id", "name", "description", "components"]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema#",
  "title": "Variables",
  "description": "Variables list (i.e., variables whose names start with '$')",

    "type": "array",
    "items": {
        "type": "object",
        "properties": {
                "nameOfVariable": {
                "type": "string",
                "description": "Name of the variable"
            },
            "typeOfVariable": {
                "type": "string",
                "description": "Type of the variable",
                "enum": ["continuous", "categorical"]
            },
            "values": {
                "type": "array",
                "description": "List of unique variable values that covers each and every one of the possible values.",
                "uniqueItems": true,
                "items": {
                    "oneOf": [
                        { "type": "string" },
                        { "type": "number" }
                    ]
                }
            }
        }
      },
    "required": ["nameOfVariable", "typeOfVariable"]
}

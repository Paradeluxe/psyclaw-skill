{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Audio",
  "description": "PsychoPy Audio component for audio playback",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier for the audio component"
    },
    "name": {
      "type": "string",
      "description": "Name of the audio component"
    },
    "filePath": {
      "oneOf": [
        {
          "type": "string",
          "description": "Path to the audio file (recommended format: .wav)"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Path to the audio file or variable reference"
    },
    "volume": {
      "oneOf": [
        {
          "type": "number",
          "description": "Volume level (0.0 to 1.0)",
          "minimum": 0.0,
          "maximum": 1.0
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Volume level (0.0 to 1.0) or variable reference",
      "default": 1.0
    },
    "stereo": {
      "type": "boolean",
      "description": "Whether to use stereo playback",
      "default": true
    },
    "loops": {
      "oneOf": [
        {
          "type": "integer",
          "description": "Number of loops (0 for once, -1 for infinite)"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Number of loops (0 for once, -1 for infinite) or variable reference",
      "default": 0
    },
    "hamming": {
      "type": "boolean",
      "description": "Whether to apply Hanning window (smooth onset/offset)",
      "default": true
    },
    "audioEngine": {
      "oneOf": [
        {
          "type": "string",
          "description": "Audio engine to use",
          "enum": ["SoundPTB", "SoundDevice", "SoundPyo", "SoundPygame"]
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Audio engine to use or variable reference",
      "default": "SoundPTB"
    },
    "audioDevice": {
      "oneOf": [
        {
          "type": "string",
          "description": "Name of the audio device to use"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Name of the audio device to use or variable reference"
    },
    "duration": {
      "oneOf": [
        {
          "type": "number",
          "description": "Duration of the audio in seconds"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Duration of the audio in seconds or variable reference"
    },
    "isPlaying": {
      "type": "boolean",
      "description": "Whether the audio is currently playing"
    },
    "isFinished": {
      "type": "boolean",
      "description": "Whether the audio has finished playing"
    }
  },
  "required": ["id", "name", "filePath"]
}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Audio",
  "description": "PsychoPy Audio/Sound component for audio playback",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier for the audio component"
    },
    "name": {
      "type": "string",
      "description": "Name of the audio component"
    },
    "sound": {
      "oneOf": [
        {
          "type": "string",
          "description": "A sound file (e.g. *.wav, *.mp3) or a number for a tone"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Sound file or variable reference"
    },
    "volume": {
      "oneOf": [
        {
          "type": "number",
          "description": "Volume level (0.0 to 1.0)",
          "minimum": 0.0,
          "maximum": 1.0
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Volume level or variable reference",
      "default": 1.0
    },
    "stopWithRoutine": {
      "oneOf": [
        {
          "type": "boolean",
          "description": "Should the sound stop when the Routine ends?"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Stop with routine or variable reference",
      "default": true
    },
    "forceEndRoutine": {
      "oneOf": [
        {
          "type": "boolean",
          "description": "Should a response force the end of the Routine?"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Force end of routine or variable reference",
      "default": true
    },
    "minTime": {
      "oneOf": [
        {
          "type": "number",
          "description": "Minimum time to play the audio in seconds"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Minimum time to play the audio in seconds or variable reference"
    },
    "maxTime": {
      "oneOf": [
        {
          "type": "number",
          "description": "Maximum time to play the audio in seconds"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Maximum time to play the audio in seconds or variable reference"
    }
  },
  "required": ["id", "name", "sound"]
}

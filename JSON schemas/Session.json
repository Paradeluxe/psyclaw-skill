{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Session",
  "description": "PsychoPy Session for experiment sessions",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier for the session"
    },
    "name": {
      "type": "string",
      "description": "Name of the session"
    },
    "loops": {
      "type": "array",
      "description": "Loops used in the session",
      "items": {
        "$ref": "Loop.json"
      }
    }
  },
  "required": ["id", "name", "description", "loops"]
}
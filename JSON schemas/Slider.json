{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Slider",
  "description": "PsychoPy Slider component for user input",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier for the slider component"
    },
    "name": {
      "type": "string",
      "description": "Name of the slider component"
    },
    "ticks": {
      "oneOf": [
        {
          "type": "array",
          "description": "Ticks on the scale (e.g. [1, 2, 3, 4, 5])",
          "items": {
            "type": "number"
          }
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Ticks on the scale or variable reference"
    },
    "labels": {
      "oneOf": [
        {
          "type": "array",
          "description": "Labels for the slider",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Labels for the slider or variable reference"
    },
    "initVal": {
      "oneOf": [
        {
          "type": "number",
          "description": "Initial value of the slider"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Initial value or variable reference",
      "default": 0.5
    },
    "forceEndRoutine": {
      "oneOf": [
        {
          "type": "boolean",
          "description": "Should a response force the end of the Routine?"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Force end of routine or variable reference",
      "default": true
    },
    "flip": {
      "oneOf": [
        {
          "type": "boolean",
          "description": "Should the slider flip its orientation?"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Flip orientation or variable reference",
      "default": false
    },
    "font": {
      "oneOf": [
        {
          "type": "string",
          "description": "Font family for labels"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Font family or variable reference",
      "default": "Arial"
    },
    "letterHeight": {
      "oneOf": [
        {
          "type": "number",
          "description": "Letter height for labels"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Letter height or variable reference",
      "default": 0.02
    },
    "pos": {
      "oneOf": [
        {
          "type": "array",
          "description": "Position on screen (x, y)",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Position on screen or variable reference",
      "default": [0, 0]
    },
    "size": {
      "oneOf": [
        {
          "type": "array",
          "description": "Size of the slider (width, height)",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Size of the slider or variable reference",
      "default": [1.0, 0.1]
    },
    "units": {
      "oneOf": [
        {
          "type": "string",
          "description": "Units to use when positioning",
          "enum": ["from exp settings", "norm", "cm", "deg", "pix", "height"]
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Units or variable reference",
      "default": "from exp settings"
    },
    "color": {
      "oneOf": [
        {
          "type": "string",
          "description": "Label color"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Label color or variable reference",
      "default": "white"
    },
    "fillColor": {
      "oneOf": [
        {
          "type": "string",
          "description": "Marker color"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Marker color or variable reference",
      "default": "white"
    },
    "borderColor": {
      "oneOf": [
        {
          "type": "string",
          "description": "Line color"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Line color or variable reference",
      "default": "white"
    },
    "opacity": {
      "oneOf": [
        {
          "type": "number",
          "description": "Slider opacity (0-1)",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Slider opacity or variable reference",
      "default": 1.0
    },
    "minTime": {
      "oneOf": [
        {
          "type": "number",
          "description": "Minimum time to display the component in seconds"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Minimum time to display the component in seconds or variable reference"
    },
    "maxTime": {
      "oneOf": [
        {
          "type": "number",
          "description": "Maximum time to display the component in seconds"
        },
        {
          "type": "object",
          "properties": {
            "$var": {
              "type": "string",
              "description": "Variable name from varList"
            }
          },
          "required": ["$var"]
        }
      ],
      "description": "Maximum time to display the component in seconds or variable reference"
    }
  },
  "required": ["id", "name"]
}

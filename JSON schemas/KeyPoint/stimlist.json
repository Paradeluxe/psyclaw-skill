{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StimList",
  "type": "array",
  "description": "A single stim list of one of the conditions in the current experiment",
  "items": {
    "oneOf": [
      {
        "type": "integer"
      },
      {
        "type": "string"
      }
    ]
  },
  "required": ["numberOfVariables", "variables", "conditions"]
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "condition(s)",
  "type": "object",
  "description": "The complete experimental design",
  "properties": {
    "dependentVariables": {
      "type": "array",
      "description": "The dependent variables in this session",
      "items": {
        "$ref": "variable.json"
      }
    },
    "independentVariables": {
      "type": "array",
      "description": "The independent variables in this session",
      "items": {
        "$ref": "variable.json"
      }
    }
  },
  "required": ["dependentVariables", "independentVariables"]
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "condition(s)",
  "type": "object",
  "description": "The complete experimental design",
  "properties": {
    "numberOfVariables": {
      "type": "integer",
      "description": "The number of variables in this session"
    },
    "variables": {
      "type": "array",
      "description": "The variables in this session",
      "items": {
        "$ref": "variable.json"
      }
    }
  },
  "required": ["numberOfVariables", "variables", "conditions"]
}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://deeppsych.org/schemas/flowchart.schema.json",
  "title": "DeepPsych Flowchart Schema",
  "description": "JSON Schema for validating DeepPsych flowchart data structure generated from card.html and used by chatbot.html",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "version",
    "timestamp",
    "routineRects",
    "connections",
    "currentRoutineCount",
    "routineIdCounter",
    "loopIdCounter"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version identifier",
      "examples": ["1.0.0"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime string indicating when the flowchart was created or last modified",
      "examples": ["2024-01-15T10:30:00.000Z"]
    },
    "routineRects": {
      "type": "array",
      "description": "Array of routine objects representing nodes in the flowchart",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/Routine"
      },
      "uniqueItems": false
    },
    "connections": {
      "type": "array",
      "description": "Array of connection objects representing edges between routines",
      "items": {
        "$ref": "#/definitions/Connection"
      }
    },
    "currentRoutineCount": {
      "type": "integer",
      "description": "Current number of routines in the flowchart",
      "minimum": 1
    },
    "routineIdCounter": {
      "type": "integer",
      "description": "Counter for generating unique routine IDs",
      "minimum": 0
    },
    "loopIdCounter": {
      "type": "integer",
      "description": "Counter for generating unique loop IDs",
      "minimum": 0
    }
  },
  "definitions": {
    "Routine": {
      "type": "object",
      "description": "A routine object representing a node in the flowchart with AVTP (Audio, Video, Text, Picture, Keyboard) configurations",
      "required": [
        "id",
        "x",
        "y",
        "width",
        "height",
        "keys",
        "duration",
        "avtp",
        "avtpData"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "integer",
          "description": "Unique identifier for the routine",
          "minimum": 0
        },
        "x": {
          "type": "number",
          "description": "X coordinate position on the canvas"
        },
        "y": {
          "type": "number",
          "description": "Y coordinate position on the canvas"
        },
        "width": {
          "type": "number",
          "description": "Width of the routine rectangle",
          "minimum": 0
        },
        "height": {
          "type": "number",
          "description": "Height of the routine rectangle",
          "minimum": 0
        },
        "borderRadius": {
          "type": "number",
          "description": "Border radius for rounded corners",
          "minimum": 0
        },
        "isDragging": {
          "type": "boolean",
          "description": "Whether the routine is currently being dragged"
        },
        "offsetX": {
          "type": "number",
          "description": "X offset for drag operation"
        },
        "offsetY": {
          "type": "number",
          "description": "Y offset for drag operation"
        },
        "keys": {
          "type": "string",
          "description": "Comma-separated key names for the routine",
          "examples": ["Key1, Key2, Key3"]
        },
        "duration": {
          "type": "integer",
          "description": "Duration of the routine in milliseconds",
          "minimum": -1
        },
        "avtp": {
          "$ref": "#/definitions/AVTPFlags",
          "description": "Flags indicating which AVTP components are enabled"
        },
        "avtpData": {
          "$ref": "#/definitions/AVTPData",
          "description": "Configuration data for enabled AVTP components"
        }
      }
    },
    "AVTPFlags": {
      "type": "object",
      "description": "Flags indicating which AVTP (Audio, Video, Text, Picture, Keyboard) components are enabled",
      "required": ["a", "v", "t", "p", "k"],
      "additionalProperties": false,
      "properties": {
        "a": {
          "type": "boolean",
          "description": "Audio enabled flag"
        },
        "v": {
          "type": "boolean",
          "description": "Video enabled flag"
        },
        "t": {
          "type": "boolean",
          "description": "Text enabled flag"
        },
        "p": {
          "type": "boolean",
          "description": "Picture enabled flag"
        },
        "k": {
          "type": "boolean",
          "description": "Keyboard enabled flag"
        }
      }
    },
    "AVTPData": {
      "type": "object",
      "description": "Configuration data for AVTP components. Each component is required only if its corresponding flag in avtp is true",
      "additionalProperties": false,
      "properties": {
        "a": {
          "$ref": "#/definitions/AudioConfig",
          "description": "Audio configuration (required if avtp.a is true)"
        },
        "v": {
          "$ref": "#/definitions/VideoConfig",
          "description": "Video configuration (required if avtp.v is true)"
        },
        "t": {
          "$ref": "#/definitions/TextConfig",
          "description": "Text configuration (required if avtp.t is true)"
        },
        "p": {
          "$ref": "#/definitions/PictureConfig",
          "description": "Picture configuration (required if avtp.p is true)"
        },
        "k": {
          "$ref": "#/definitions/KeyboardConfig",
          "description": "Keyboard configuration (required if avtp.k is true)"
        }
      }
    },
    "TextConfig": {
      "type": "object",
      "description": "Configuration for text stimulus in PsychoPy/PsychoJS format",
      "required": [
        "enabled",
        "label",
        "type",
        "text",
        "font",
        "letterHeight",
        "color",
        "pos",
        "ori",
        "opacity",
        "units",
        "startTime",
        "duration",
        "contrast",
        "flip",
        "languageStyle",
        "draggable"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether this text component is enabled"
        },
        "label": {
          "type": "string",
          "description": "Label identifier for this component"
        },
        "type": {
          "type": "string",
          "const": "text",
          "description": "Component type (constant: 'text')"
        },
        "text": {
          "type": "string",
          "description": "The actual text content to display"
        },
        "font": {
          "type": "string",
          "description": "Font family name",
          "examples": ["Arial", "Courier New", "Times New Roman"]
        },
        "letterHeight": {
          "type": "number",
          "description": "Height of letters in degrees of visual angle"
        },
        "color": {
          "type": "string",
          "description": "Text color as color name or hex value",
          "examples": ["white", "#FFFFFF", "black", "#000000"]
        },
        "pos": {
          "type": "array",
          "description": "Position coordinates [x, y]",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "ori": {
          "type": "integer",
          "description": "Orientation in degrees"
        },
        "opacity": {
          "type": "number",
          "description": "Opacity value from 0.0 (transparent) to 1.0 (opaque)",
          "minimum": 0,
          "maximum": 1
        },
        "units": {
          "type": "string",
          "description": "Units for positioning (e.g., 'deg', 'cm', 'pix', 'norm', 'height')",
          "examples": ["deg", "cm", "pix", "norm", "height"]
        },
        "startTime": {
          "type": "integer",
          "description": "Start time in milliseconds relative to routine start",
          "minimum": 0
        },
        "duration": {
          "type": "integer",
          "description": "Duration in milliseconds",
          "minimum": -1
        },
        "contrast": {
          "type": "number",
          "description": "Contrast value from 0.0 to 1.0",
          "minimum": 0,
          "maximum": 1
        },
        "wrapWidth": {
          "type": "number",
          "description": "Width for text wrapping (optional)"
        },
        "flip": {
          "type": "string",
          "description": "Flip direction",
          "enum": ["None", "Horizontal", "Vertical", "Both"]
        },
        "languageStyle": {
          "type": "string",
          "description": "Text direction style",
          "enum": ["LTR", "RTL"]
        },
        "draggable": {
          "type": "boolean",
          "description": "Whether the text can be dragged by the user"
        }
      }
    },
    "PictureConfig": {
      "type": "object",
      "description": "Configuration for image/picture stimulus in PsychoPy/PsychoJS format",
      "required": [
        "enabled",
        "label",
        "type",
        "path",
        "size",
        "pos",
        "opacity",
        "startTime",
        "duration",
        "ori",
        "flip",
        "units"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether this picture component is enabled"
        },
        "label": {
          "type": "string",
          "description": "Label identifier for this component"
        },
        "type": {
          "type": "string",
          "const": "image",
          "description": "Component type (constant: 'image')"
        },
        "path": {
          "type": "string",
          "description": "File path or URL to the image"
        },
        "size": {
          "type": "array",
          "description": "Size [width, height]. Use null for auto-sizing",
          "items": {
            "type": ["number", "null"]
          },
          "minItems": 2,
          "maxItems": 2
        },
        "pos": {
          "type": "array",
          "description": "Position coordinates [x, y]",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "opacity": {
          "type": "number",
          "description": "Opacity value from 0.0 (transparent) to 1.0 (opaque)",
          "minimum": 0,
          "maximum": 1
        },
        "startTime": {
          "type": "integer",
          "description": "Start time in milliseconds relative to routine start",
          "minimum": 0
        },
        "duration": {
          "type": "integer",
          "description": "Duration in milliseconds",
          "minimum": -1
        },
        "ori": {
          "type": "integer",
          "description": "Orientation in degrees"
        },
        "flip": {
          "type": "string",
          "description": "Flip direction",
          "enum": ["None", "Horizontal", "Vertical", "Both"]
        },
        "units": {
          "type": "string",
          "description": "Units for positioning",
          "examples": ["deg", "cm", "pix", "norm", "height"]
        }
      }
    },
    "AudioConfig": {
      "type": "object",
      "description": "Configuration for audio stimulus in PsychoPy/PsychoJS format",
      "required": [
        "enabled",
        "label",
        "type",
        "path",
        "volume",
        "startTime",
        "duration",
        "stopWithRoutine",
        "forceEndRoutine"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether this audio component is enabled"
        },
        "label": {
          "type": "string",
          "description": "Label identifier for this component"
        },
        "type": {
          "type": "string",
          "const": "audio",
          "description": "Component type (constant: 'audio')"
        },
        "path": {
          "type": "string",
          "description": "File path or URL to the audio file"
        },
        "volume": {
          "type": "number",
          "description": "Volume level from 0.0 (silent) to 1.0 (maximum)",
          "minimum": 0,
          "maximum": 1
        },
        "startTime": {
          "type": "integer",
          "description": "Start time in milliseconds relative to routine start",
          "minimum": 0
        },
        "duration": {
          "type": "integer",
          "description": "Duration in milliseconds. Use -1 for until completion",
          "minimum": -1
        },
        "stopWithRoutine": {
          "type": "boolean",
          "description": "Whether to stop audio when routine ends"
        },
        "forceEndRoutine": {
          "type": "boolean",
          "description": "Whether audio completion should force end the routine"
        }
      }
    },
    "VideoConfig": {
      "type": "object",
      "description": "Configuration for video stimulus in PsychoPy/PsychoJS format",
      "required": [
        "enabled",
        "label",
        "type",
        "path",
        "volume",
        "size",
        "anchor",
        "loop",
        "startTime",
        "duration",
        "units",
        "opacity",
        "stopWithRoutine",
        "forceEndRoutine"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether this video component is enabled"
        },
        "label": {
          "type": "string",
          "description": "Label identifier for this component"
        },
        "type": {
          "type": "string",
          "const": "video",
          "description": "Component type (constant: 'video')"
        },
        "path": {
          "type": "string",
          "description": "File path or URL to the video file"
        },
        "volume": {
          "type": "number",
          "description": "Volume level from 0.0 (silent) to 1.0 (maximum)",
          "minimum": 0,
          "maximum": 1
        },
        "size": {
          "type": "array",
          "description": "Size [width, height]. Use null for auto-sizing",
          "items": {
            "type": ["number", "null"]
          },
          "minItems": 2,
          "maxItems": 2
        },
        "anchor": {
          "type": "string",
          "description": "Anchor point for positioning",
          "examples": ["center", "top-left", "top-right", "bottom-left", "bottom-right"]
        },
        "loop": {
          "type": "boolean",
          "description": "Whether to loop the video"
        },
        "startTime": {
          "type": "integer",
          "description": "Start time in milliseconds relative to routine start",
          "minimum": 0
        },
        "duration": {
          "type": "integer",
          "description": "Duration in milliseconds",
          "minimum": -1
        },
        "units": {
          "type": "string",
          "description": "Units for positioning",
          "examples": ["deg", "cm", "pix", "norm", "height"]
        },
        "opacity": {
          "type": "number",
          "description": "Opacity value from 0.0 (transparent) to 1.0 (opaque)",
          "minimum": 0,
          "maximum": 1
        },
        "stopWithRoutine": {
          "type": "boolean",
          "description": "Whether to stop video when routine ends"
        },
        "forceEndRoutine": {
          "type": "boolean",
          "description": "Whether video completion should force end the routine"
        }
      }
    },
    "KeyboardConfig": {
      "type": "object",
      "description": "Configuration for keyboard response component in PsychoPy/PsychoJS format",
      "required": [
        "enabled",
        "label",
        "type",
        "keys",
        "startTime",
        "duration",
        "forceEndRoutine"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether this keyboard component is enabled"
        },
        "label": {
          "type": "string",
          "description": "Label identifier for this component"
        },
        "type": {
          "type": "string",
          "const": "keyboard",
          "description": "Component type (constant: 'keyboard')"
        },
        "keys": {
          "type": "string",
          "description": "Comma-separated key names to listen for",
          "examples": ["space", "left, right", "escape"]
        },
        "startTime": {
          "type": "integer",
          "description": "Start time in milliseconds relative to routine start",
          "minimum": 0
        },
        "duration": {
          "type": "integer",
          "description": "Duration in milliseconds to listen for keypresses",
          "minimum": -1
        },
        "forceEndRoutine": {
          "type": "boolean",
          "description": "Whether a keypress should force end the routine"
        }
      }
    },
    "Connection": {
      "type": "object",
      "description": "A connection object representing an edge between two routines in the flowchart, potentially with loop information",
      "required": [
        "start",
        "end",
        "depth",
        "loopIsTrials"
      ],
      "additionalProperties": false,
      "properties": {
        "start": {
          "$ref": "#/definitions/ConnectionEndpoint",
          "description": "Start point of the connection"
        },
        "end": {
          "$ref": "#/definitions/ConnectionEndpoint",
          "description": "End point of the connection"
        },
        "depth": {
          "type": "integer",
          "description": "Depth level for nested loops",
          "minimum": 0
        },
        "loopName": {
          "type": "string",
          "description": "Name of the loop block (optional, for loop blocks)"
        },
        "loopReps": {
          "type": "integer",
          "description": "Number of repetitions for the loop",
          "minimum": 1
        },
        "loopType": {
          "type": "string",
          "description": "Type of loop iteration",
          "enum": ["sequential", "random"]
        },
        "loopConditions": {
          "type": "string",
          "description": "JSON string representing an array of loop condition objects",
          "contentMediaType": "application/json",
          "contentSchema": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/LoopCondition"
            }
          }
        },
        "loopIsTrials": {
          "type": "boolean",
          "description": "Whether this connection represents a trials loop"
        }
      },
      "if": {
        "required": ["loopName"]
      },
      "then": {
        "required": ["loopReps", "loopType"],
        "description": "When loopName is present, loopReps and loopType are required"
      }
    },
    "ConnectionEndpoint": {
      "type": "object",
      "description": "An endpoint of a connection (start or end point)",
      "required": [
        "x",
        "y",
        "label",
        "isSnapTarget"
      ],
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "number",
          "description": "X coordinate of the endpoint"
        },
        "y": {
          "type": "number",
          "description": "Y coordinate of the endpoint"
        },
        "label": {
          "type": "integer",
          "description": "Label of the routine (routine id number)"
        },
        "isSnapTarget": {
          "type": "boolean",
          "description": "Whether this endpoint is a snap target for connections"
        }
      }
    },
    "LoopCondition": {
      "type": "object",
      "description": "A condition object used in loop conditions to determine loop execution",
      "required": [
        "variable",
        "operator",
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "variable": {
          "type": "string",
          "description": "Variable name to evaluate"
        },
        "operator": {
          "type": "string",
          "description": "Comparison operator",
          "enum": ["==", "!=", ">", "<", ">=", "<="]
        },
        "value": {
          "type": ["string", "number"],
          "description": "Value to compare against"
        }
      }
    }
  }
}

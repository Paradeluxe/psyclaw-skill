{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://deeppsych.org/schemas/flowchart.schema.json",
  "title": "PsyClaw Flowchart Schema",
  "description": "JSON Schema for validating PsyClaw flowchart data structure (v2.0 format). Used for save/import operations between psyclaw.html and chatbot.html.",
  "version": "2.0.0",
  "type": "object",
  "required": ["flowchart"],
  "additionalProperties": false,
  "properties": {
    "flowchart": {
      "type": "array",
      "description": "Unified array of routines and loops defining the experiment flow. Contains both routine objects (experiment steps with stimuli/responses) and loop objects (repetition structures). LOOP VALIDATION RULES: 1) Nested loops are allowed (one loop completely inside another). 2) Sequential loops are allowed (no overlapping routines). 3) Crossing/overlapping loops are FORBIDDEN - loops must not partially share routines. Examples: Loop A containing routines at points 2-8, with Loop B containing routines at points 4-6 is VALID (nested). Loop A with routines 2-4 and Loop B with routines 6-8 is VALID (sequential). Loop A with routines 2-6 and Loop B with routines 4-8 is INVALID (crossing).",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/definitions/Routine"
          },
          {
            "$ref": "#/definitions/Loop"
          }
        ]
      }
    }
  },
  "definitions": {
    "Routine": {
      "type": "object",
      "description": "A routine representing a single trial/stimulus presentation. The frontend handles visual layout (position, size) - this schema only defines the experiment logic.",
      "required": ["name", "Point", "components"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Display name of the routine",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
          "maxLength": 20
        },
        "Point": {
          "type": "number",
          "description": "Point in the flowchart where this routine locates. Must be an even number (2, 4, 6, 8...). A routine belongs to a loop if and only if: loop.startPoint <= Point <= loop.endPoint. This means the routine is within the loop's inclusive range.",
          "minimum": 2,
          "default": 2
        },
        "components": {
          "type": "array",
          "description": "Array of stimulus/response components in this routine. Each routine must have at least one component (stimulus or response). Empty routines are not allowed.",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/Component"
          }
        }
      }
    },
    "Component": {
      "oneOf": [
        { "$ref": "#/definitions/AudioComponent" },
        { "$ref": "#/definitions/VideoComponent" },
        { "$ref": "#/definitions/TextComponent" },
        { "$ref": "#/definitions/ImageComponent" },
        { "$ref": "#/definitions/KeyboardComponent" }
      ]
    },
    "AudioComponent": {
      "type": "object",
      "description": "Audio stimulus component",
      "required": ["name", "type", "startTime", "duration"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the audio component",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "type": {
          "type": "string",
          "enum": ["audio"]
        },
        "path": {
          "type": "string",
          "description": "File path for audio file"
        },
        "startTime": {
          "type": "number",
          "description": "Start time in milliseconds",
          "minimum": 0,
          "default": 0
        },
        "duration": {
          "type": "number",
          "description": "Duration in milliseconds (-1 for indefinite)",
          "minimum": -1,
          "default": -1
        },
        "stopWithRoutine": {
          "type": "boolean",
          "description": "Whether to stop when routine ends",
          "default": true
        },
        "volume": {
          "type": "number",
          "description": "Volume for audio (0.0 to 1.0)",
          "minimum": 0,
          "maximum": 1,
          "default": 1
        },
        "loop": {
          "type": "boolean",
          "description": "Whether to loop audio",
          "default": false
        },
        "hamming": {
          "type": "boolean",
          "description": "Apply Hamming window to audio",
          "default": true
        },
        "deviceLabel": {
          "type": "string",
          "description": "Audio device label"
        }
      }
    },
    "VideoComponent": {
      "type": "object",
      "description": "Video stimulus component",
      "required": ["name", "type", "startTime", "duration"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the video component",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "type": {
          "type": "string",
          "enum": ["video"]
        },
        "path": {
          "type": "string",
          "description": "File path for video file"
        },
        "pos": {
          "type": "array",
          "description": "Position [x, y]",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2,
          "default": [0, 0]
        },
        "size": {
          "type": "array",
          "description": "Size [width, height] (null values auto-calculate)",
          "items": { "type": ["number", "null"] },
          "minItems": 2,
          "maxItems": 2
        },
        "ori": {
          "type": "number",
          "description": "Orientation in degrees",
          "default": 0
        },
        "opacity": {
          "type": "number",
          "description": "Opacity value from 0.0 (transparent) to 1.0 (opaque)",
          "minimum": 0,
          "maximum": 1,
          "default": 1
        },
        "startTime": {
          "type": "number",
          "description": "Start time in milliseconds",
          "minimum": 0,
          "default": 0
        },
        "duration": {
          "type": "number",
          "description": "Duration in milliseconds (-1 for indefinite)",
          "minimum": -1,
          "default": -1
        },
        "stopWithRoutine": {
          "type": "boolean",
          "description": "Whether to stop when routine ends",
          "default": true
        },
        "volume": {
          "type": "number",
          "description": "Volume for video (0.0 to 1.0)",
          "minimum": 0,
          "maximum": 1,
          "default": 1
        },
        "loop": {
          "type": "boolean",
          "description": "Whether to loop video",
          "default": false
        },
        "flip": {
          "type": "string",
          "description": "Flip mode",
          "enum": ["None", "Horizontal", "Vertical", "Both"],
          "default": "None"
        },
        "units": {
          "type": "string",
          "description": "Units for positioning",
          "enum": ["from exp settings", "height", "norm", "pix", "cm", "deg"],
          "default": "from exp settings"
        }
      }
    },
    "TextComponent": {
      "type": "object",
      "description": "Text stimulus component",
      "required": ["name", "type", "text", "startTime", "duration"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the text component",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "type": {
          "type": "string",
          "enum": ["text"]
        },
        "text": {
          "type": "string",
          "description": "Text content"
        },
        "color": {
          "type": "string",
          "description": "Color value (e.g., 'white', 'red', '#ffffff')"
        },
        "font": {
          "type": "string",
          "description": "Font family name"
        },
        "letterHeight": {
          "type": "number",
          "description": "Font size in height units",
          "default": 0.05
        },
        "pos": {
          "type": "array",
          "description": "Position [x, y]",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2,
          "default": [0, 0]
        },
        "size": {
          "type": "array",
          "description": "Size [width, height] (null values auto-calculate)",
          "items": { "type": ["number", "null"] },
          "minItems": 2,
          "maxItems": 2
        },
        "ori": {
          "type": "number",
          "description": "Orientation in degrees",
          "default": 0
        },
        "opacity": {
          "type": "number",
          "description": "Opacity value from 0.0 (transparent) to 1.0 (opaque)",
          "minimum": 0,
          "maximum": 1,
          "default": 1
        },
        "startTime": {
          "type": "number",
          "description": "Start time in milliseconds",
          "minimum": 0,
          "default": 0
        },
        "duration": {
          "type": "number",
          "description": "Duration in milliseconds (-1 for indefinite)",
          "minimum": -1,
          "default": -1
        },
        "stopWithRoutine": {
          "type": "boolean",
          "description": "Whether to stop when routine ends",
          "default": true
        },
        "units": {
          "type": "string",
          "description": "Units for positioning",
          "enum": ["from exp settings", "height", "norm", "pix", "cm", "deg"],
          "default": "from exp settings"
        },
        "languageStyle": {
          "type": "string",
          "description": "Language direction",
          "enum": ["LTR", "RTL"],
          "default": "LTR"
        },
        "wrapWidth": {
          "type": "number",
          "description": "Text wrap width"
        },
        "anchor": {
          "type": "string",
          "description": "Anchor point for positioning",
          "enum": ["center", "top-center", "bottom-center", "left-center", "right-center", "top-left", "top-right", "bottom-left", "bottom-right"],
          "default": "center"
        },
        "colorSpace": {
          "type": "string",
          "description": "Color space",
          "enum": ["rgb", "dkl", "hsv", "hex"],
          "default": "rgb"
        }
      }
    },
    "ImageComponent": {
      "type": "object",
      "description": "Image stimulus component",
      "required": ["name", "type", "startTime", "duration"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the image component",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "type": {
          "type": "string",
          "enum": ["image"]
        },
        "path": {
          "type": "string",
          "description": "File path for image file"
        },
        "pos": {
          "type": "array",
          "description": "Position [x, y]",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2,
          "default": [0, 0]
        },
        "size": {
          "type": "array",
          "description": "Size [width, height] (null values auto-calculate)",
          "items": { "type": ["number", "null"] },
          "minItems": 2,
          "maxItems": 2
        },
        "ori": {
          "type": "number",
          "description": "Orientation in degrees",
          "default": 0
        },
        "opacity": {
          "type": "number",
          "description": "Opacity value from 0.0 (transparent) to 1.0 (opaque)",
          "minimum": 0,
          "maximum": 1,
          "default": 1
        },
        "startTime": {
          "type": "number",
          "description": "Start time in milliseconds",
          "minimum": 0,
          "default": 0
        },
        "duration": {
          "type": "number",
          "description": "Duration in milliseconds (-1 for indefinite)",
          "minimum": -1,
          "default": -1
        },
        "stopWithRoutine": {
          "type": "boolean",
          "description": "Whether to stop when routine ends",
          "default": true
        },
        "contrast": {
          "type": "number",
          "description": "Contrast value (0.0 to 1.0)",
          "minimum": 0,
          "maximum": 1,
          "default": 1
        },
        "flip": {
          "type": "string",
          "description": "Flip mode",
          "enum": ["None", "Horizontal", "Vertical", "Both"],
          "default": "None"
        },
        "units": {
          "type": "string",
          "description": "Units for positioning",
          "enum": ["from exp settings", "height", "norm", "pix", "cm", "deg"],
          "default": "from exp settings"
        },
        "interpolate": {
          "type": "string",
          "description": "Image interpolation method",
          "enum": ["linear", "nearest"],
          "default": "linear"
        },
        "textureRes": {
          "type": "integer",
          "description": "Texture resolution for images",
          "enum": [32, 64, 128, 256, 512],
          "default": 128
        },
        "colorSpace": {
          "type": "string",
          "description": "Color space",
          "enum": ["rgb", "dkl", "hsv", "hex"],
          "default": "rgb"
        },
        "draggable": {
          "type": "boolean",
          "description": "Whether the stimulus is draggable",
          "default": false
        }
      }
    },
    "KeyboardComponent": {
      "type": "object",
      "description": "Keyboard response component",
      "required": ["name", "type", "startTime", "duration", "keys"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the keyboard component",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "type": {
          "type": "string",
          "enum": ["keyboard"]
        },
        "startTime": {
          "type": "number",
          "description": "Start time in milliseconds",
          "minimum": 0,
          "default": 0
        },
        "duration": {
          "type": "number",
          "description": "Duration in milliseconds (-1 for indefinite)",
          "minimum": -1,
          "default": -1
        },
        "stopWithRoutine": {
          "type": "boolean",
          "description": "Whether to stop when routine ends",
          "default": true
        },
        "forceEndRoutine": {
          "type": "boolean",
          "description": "Whether to force end routine on response",
          "default": false
        },
        "keys": {
          "type": "string",
          "description": "Comma-separated keyboard keys (e.g., 'space,return,escape')"
        },
        "registerOn": {
          "type": "string",
          "description": "When to register key press",
          "enum": ["press", "release"],
          "default": "press"
        }
      }
    },
    "Condition": {
      "type": "object",
      "description": "A condition object representing one trial with specific parameter values",
      "required": ["name", "weight"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Display name describing what this condition represents (e.g., 'congruent left', 'high difficulty - valid cue')"
        },
        "weight": {
          "type": "integer",
          "description": "Weight of this condition for randomization",
          "minimum": 1,
          "default": 1
        },
        "values": {
          "type": "object",
          "description": "Dictionary mapping a single variable name to its possible values. Only ONE variable is allowed per condition. Key is the variable name (e.g., '$color$'), value is an array of all possible values for that variable.",
          "minProperties": 1,
          "maxProperties": 1,
          "additionalProperties": {
            "type": "array",
            "description": "All possible values for this variable",
            "items": {
              "oneOf": [
                { "type": "string", "description": "String value or $var$ reference" },
                { "type": "number", "description": "Numeric value" },
                { "type": "boolean", "description": "Boolean value" }
              ]
            }
          }
        }
      }
    },
    "Loop": {
      "type": "object",
      "description": "A loop (trial handler) that repeats a set of routines multiple times with varying conditions. Loops contain a list of routines and/or nested loops. IMPORTANT: 1) Loops cannot overlap or cross. For any two loops, either one must be completely inside the other (nested), or they must be completely separate with no overlapping routines. 2) The loop's startPoint and endPoint are automatically calculated at render time based on its contained routines: startPoint = first routine's Point - 1, endPoint = last routine's Point + 1. 3) ROUTINE-LOOP MEMBERSHIP: A routine belongs to a loop if and only if it is included in the loop's list array (directly or nested).",
      "required": ["name", "nRounds", "type", "list"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the loop",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "nRounds": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of rounds for all weighted conditions",
          "default": 1
        },
        "type": {
          "type": "string",
          "enum": ["sequential", "random", "fullRandom"],
          "description": "How to order trials: sequential (fixed order), random (shuffle), fullRandom (completely random)",
          "default": "sequential"
        },
        "conditions": {
          "type": "array",
          "description": "Array of condition objects, one per trial. Each object contains parameter values for that trial.",
          "items": {
            "$ref": "#/definitions/Condition"
          }
        },
        "list": {
          "type": "array",
          "description": "Array of nested loops and/or routines to be executed within this loop. Allows nested loop structures and routine references. The loop's startPoint and endPoint are calculated from this list: startPoint = first routine's Point - 1, endPoint = last routine's Point + 1.",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "$ref": "#/definitions/Loop"
              },
              {
                "$ref": "#/definitions/Routine"
              }
            ]
          }
        }
      }
    }
  }
}
